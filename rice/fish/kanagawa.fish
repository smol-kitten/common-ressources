# Theme: Kanagawa
# Source: https://github.com/rebelot/kanagawa.nvim
# Usage: source this file or copy to ~/.config/fish/conf.d/kanagawa.fish
#   source ~/.config/fish/themes/kanagawa.fish

# Fish color variables (hex without #)
set -U fish_color_normal          dcd7ba
set -U fish_color_command         7e9cd8
set -U fish_color_keyword         957fb8
set -U fish_color_quote           76946a
set -U fish_color_redirection     6a9589
set -U fish_color_end             957fb8
set -U fish_color_error           c34043
set -U fish_color_param           dcd7ba
set -U fish_color_valid_path      6a9589 --underline
set -U fish_color_comment         727169
set -U fish_color_selection       --background=2d4f67
set -U fish_color_operator        957fb8
set -U fish_color_escape          c0a36e
set -U fish_color_autosuggestion  727169
set -U fish_color_user            76946a
set -U fish_color_host            7e9cd8
set -U fish_color_host_remote     6a9589
set -U fish_color_status          c34043
set -U fish_color_cancel          c34043
set -U fish_color_search_match    --background=c0a36e

# Pager colors
set -U fish_pager_color_progress             727169
set -U fish_pager_color_prefix               7e9cd8
set -U fish_pager_color_completion           dcd7ba
set -U fish_pager_color_description          727169
set -U fish_pager_color_selected_background  --background=2d4f67
set -U fish_pager_color_selected_prefix      7e9cd8 --bold
set -U fish_pager_color_selected_completion  dcd7ba --bold
