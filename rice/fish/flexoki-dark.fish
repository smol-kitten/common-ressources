# Theme: Flexoki Dark
# Source: https://stephango.com/flexoki
# Usage: source this file or copy to ~/.config/fish/conf.d/flexoki-dark.fish
#   source ~/.config/fish/themes/flexoki-dark.fish

# Fish color variables (hex without #)
set -U fish_color_normal          CECDC3
set -U fish_color_command         4385BE
set -U fish_color_keyword         CE5D97
set -U fish_color_quote           879A39
set -U fish_color_redirection     3AA99F
set -U fish_color_end             CE5D97
set -U fish_color_error           D14D41
set -U fish_color_param           CECDC3
set -U fish_color_valid_path      3AA99F --underline
set -U fish_color_comment         575653
set -U fish_color_selection       --background=282726
set -U fish_color_operator        CE5D97
set -U fish_color_escape          D0A215
set -U fish_color_autosuggestion  575653
set -U fish_color_user            879A39
set -U fish_color_host            4385BE
set -U fish_color_host_remote     3AA99F
set -U fish_color_status          D14D41
set -U fish_color_cancel          D14D41
set -U fish_color_search_match    --background=D0A215

# Pager colors
set -U fish_pager_color_progress             575653
set -U fish_pager_color_prefix               4385BE
set -U fish_pager_color_completion           CECDC3
set -U fish_pager_color_description          575653
set -U fish_pager_color_selected_background  --background=282726
set -U fish_pager_color_selected_prefix      4385BE --bold
set -U fish_pager_color_selected_completion  CECDC3 --bold
