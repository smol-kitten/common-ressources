# Theme: Catppuccin Mocha
# Source: https://github.com/catppuccin/catppuccin
# Usage: source this file or copy to ~/.config/fish/conf.d/catppuccin-mocha.fish
#   source ~/.config/fish/themes/catppuccin-mocha.fish

# Fish color variables (hex without #)
set -U fish_color_normal          CDD6F4
set -U fish_color_command         89B4FA
set -U fish_color_keyword         F5C2E7
set -U fish_color_quote           A6E3A1
set -U fish_color_redirection     94E2D5
set -U fish_color_end             F5C2E7
set -U fish_color_error           F38BA8
set -U fish_color_param           CDD6F4
set -U fish_color_valid_path      94E2D5 --underline
set -U fish_color_comment         585B70
set -U fish_color_selection       --background=585B70
set -U fish_color_operator        F5C2E7
set -U fish_color_escape          F9E2AF
set -U fish_color_autosuggestion  585B70
set -U fish_color_user            A6E3A1
set -U fish_color_host            89B4FA
set -U fish_color_host_remote     94E2D5
set -U fish_color_status          F38BA8
set -U fish_color_cancel          F38BA8
set -U fish_color_search_match    --background=F9E2AF

# Pager colors
set -U fish_pager_color_progress             585B70
set -U fish_pager_color_prefix               89B4FA
set -U fish_pager_color_completion           CDD6F4
set -U fish_pager_color_description          585B70
set -U fish_pager_color_selected_background  --background=585B70
set -U fish_pager_color_selected_prefix      89B4FA --bold
set -U fish_pager_color_selected_completion  CDD6F4 --bold
