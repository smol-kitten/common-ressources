# Theme: Dracula
# Source: https://draculatheme.com
# Usage: source this file or copy to ~/.config/fish/conf.d/dracula.fish
#   source ~/.config/fish/themes/dracula.fish

# Fish color variables (hex without #)
set -U fish_color_normal          F8F8F2
set -U fish_color_command         BD93F9
set -U fish_color_keyword         FF79C6
set -U fish_color_quote           50FA7B
set -U fish_color_redirection     8BE9FD
set -U fish_color_end             FF79C6
set -U fish_color_error           FF5555
set -U fish_color_param           F8F8F2
set -U fish_color_valid_path      8BE9FD --underline
set -U fish_color_comment         6272A4
set -U fish_color_selection       --background=44475A
set -U fish_color_operator        FF79C6
set -U fish_color_escape          F1FA8C
set -U fish_color_autosuggestion  6272A4
set -U fish_color_user            50FA7B
set -U fish_color_host            BD93F9
set -U fish_color_host_remote     8BE9FD
set -U fish_color_status          FF5555
set -U fish_color_cancel          FF5555
set -U fish_color_search_match    --background=F1FA8C

# Pager colors
set -U fish_pager_color_progress             6272A4
set -U fish_pager_color_prefix               BD93F9
set -U fish_pager_color_completion           F8F8F2
set -U fish_pager_color_description          6272A4
set -U fish_pager_color_selected_background  --background=44475A
set -U fish_pager_color_selected_prefix      BD93F9 --bold
set -U fish_pager_color_selected_completion  F8F8F2 --bold
