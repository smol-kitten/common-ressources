# Theme: Ayu Dark
# Source: https://github.com/dempfi/ayu
# Usage: source this file or copy to ~/.config/fish/conf.d/ayu-dark.fish
#   source ~/.config/fish/themes/ayu-dark.fish

# Fish color variables (hex without #)
set -U fish_color_normal          b3b1ad
set -U fish_color_command         53bdfa
set -U fish_color_keyword         fae994
set -U fish_color_quote           91b362
set -U fish_color_redirection     90e1c6
set -U fish_color_end             fae994
set -U fish_color_error           ea6c73
set -U fish_color_param           b3b1ad
set -U fish_color_valid_path      90e1c6 --underline
set -U fish_color_comment         686868
set -U fish_color_selection       --background=273747
set -U fish_color_operator        fae994
set -U fish_color_escape          f9af4f
set -U fish_color_autosuggestion  686868
set -U fish_color_user            91b362
set -U fish_color_host            53bdfa
set -U fish_color_host_remote     90e1c6
set -U fish_color_status          ea6c73
set -U fish_color_cancel          ea6c73
set -U fish_color_search_match    --background=f9af4f

# Pager colors
set -U fish_pager_color_progress             686868
set -U fish_pager_color_prefix               53bdfa
set -U fish_pager_color_completion           b3b1ad
set -U fish_pager_color_description          686868
set -U fish_pager_color_selected_background  --background=273747
set -U fish_pager_color_selected_prefix      53bdfa --bold
set -U fish_pager_color_selected_completion  b3b1ad --bold
