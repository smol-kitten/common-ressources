# Theme: Rose Piné
# Source: https://rosepinetheme.com
# Usage: source this file or copy to ~/.config/fish/conf.d/rose-pine.fish
#   source ~/.config/fish/themes/rose-pine.fish

# Fish color variables (hex without #)
set -U fish_color_normal          e0def4
set -U fish_color_command         9ccfd8
set -U fish_color_keyword         c4a7e7
set -U fish_color_quote           31748f
set -U fish_color_redirection     ebbcba
set -U fish_color_end             c4a7e7
set -U fish_color_error           eb6f92
set -U fish_color_param           e0def4
set -U fish_color_valid_path      ebbcba --underline
set -U fish_color_comment         6e6a86
set -U fish_color_selection       --background=403d52
set -U fish_color_operator        c4a7e7
set -U fish_color_escape          f6c177
set -U fish_color_autosuggestion  6e6a86
set -U fish_color_user            31748f
set -U fish_color_host            9ccfd8
set -U fish_color_host_remote     ebbcba
set -U fish_color_status          eb6f92
set -U fish_color_cancel          eb6f92
set -U fish_color_search_match    --background=f6c177

# Pager colors
set -U fish_pager_color_progress             6e6a86
set -U fish_pager_color_prefix               9ccfd8
set -U fish_pager_color_completion           e0def4
set -U fish_pager_color_description          6e6a86
set -U fish_pager_color_selected_background  --background=403d52
set -U fish_pager_color_selected_prefix      9ccfd8 --bold
set -U fish_pager_color_selected_completion  e0def4 --bold
