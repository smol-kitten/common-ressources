# Theme: Catppuccin Frappe
# Source: https://github.com/catppuccin/catppuccin
# Usage: source this file or copy to ~/.config/fish/conf.d/catppuccin-frappe.fish
#   source ~/.config/fish/themes/catppuccin-frappe.fish

# Fish color variables (hex without #)
set -U fish_color_normal          C6D0F5
set -U fish_color_command         8CAAEE
set -U fish_color_keyword         F4B8E4
set -U fish_color_quote           A6D189
set -U fish_color_redirection     81C8BE
set -U fish_color_end             F4B8E4
set -U fish_color_error           E78284
set -U fish_color_param           C6D0F5
set -U fish_color_valid_path      81C8BE --underline
set -U fish_color_comment         626880
set -U fish_color_selection       --background=626880
set -U fish_color_operator        F4B8E4
set -U fish_color_escape          E5C890
set -U fish_color_autosuggestion  626880
set -U fish_color_user            A6D189
set -U fish_color_host            8CAAEE
set -U fish_color_host_remote     81C8BE
set -U fish_color_status          E78284
set -U fish_color_cancel          E78284
set -U fish_color_search_match    --background=E5C890

# Pager colors
set -U fish_pager_color_progress             626880
set -U fish_pager_color_prefix               8CAAEE
set -U fish_pager_color_completion           C6D0F5
set -U fish_pager_color_description          626880
set -U fish_pager_color_selected_background  --background=626880
set -U fish_pager_color_selected_prefix      8CAAEE --bold
set -U fish_pager_color_selected_completion  C6D0F5 --bold
