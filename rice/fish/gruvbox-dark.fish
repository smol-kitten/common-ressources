# Theme: Gruvbox Dark
# Source: https://github.com/morhetz/gruvbox
# Usage: source this file or copy to ~/.config/fish/conf.d/gruvbox-dark.fish
#   source ~/.config/fish/themes/gruvbox-dark.fish

# Fish color variables (hex without #)
set -U fish_color_normal          EBDBB2
set -U fish_color_command         458588
set -U fish_color_keyword         B16286
set -U fish_color_quote           98971A
set -U fish_color_redirection     689D6A
set -U fish_color_end             B16286
set -U fish_color_error           CC241D
set -U fish_color_param           EBDBB2
set -U fish_color_valid_path      689D6A --underline
set -U fish_color_comment         928374
set -U fish_color_selection       --background=3C3836
set -U fish_color_operator        B16286
set -U fish_color_escape          D79921
set -U fish_color_autosuggestion  928374
set -U fish_color_user            98971A
set -U fish_color_host            458588
set -U fish_color_host_remote     689D6A
set -U fish_color_status          CC241D
set -U fish_color_cancel          CC241D
set -U fish_color_search_match    --background=D79921

# Pager colors
set -U fish_pager_color_progress             928374
set -U fish_pager_color_prefix               458588
set -U fish_pager_color_completion           EBDBB2
set -U fish_pager_color_description          928374
set -U fish_pager_color_selected_background  --background=3C3836
set -U fish_pager_color_selected_prefix      458588 --bold
set -U fish_pager_color_selected_completion  EBDBB2 --bold
