# Theme: Everforest Dark
# Source: https://github.com/sainnhe/everforest
# Usage: source this file or copy to ~/.config/fish/conf.d/everforest-dark.fish
#   source ~/.config/fish/themes/everforest-dark.fish

# Fish color variables (hex without #)
set -U fish_color_normal          d3c6aa
set -U fish_color_command         7fbbb3
set -U fish_color_keyword         d699b6
set -U fish_color_quote           a7c080
set -U fish_color_redirection     83c092
set -U fish_color_end             d699b6
set -U fish_color_error           e67e80
set -U fish_color_param           d3c6aa
set -U fish_color_valid_path      83c092 --underline
set -U fish_color_comment         5c6a72
set -U fish_color_selection       --background=475258
set -U fish_color_operator        d699b6
set -U fish_color_escape          dbbc7f
set -U fish_color_autosuggestion  5c6a72
set -U fish_color_user            a7c080
set -U fish_color_host            7fbbb3
set -U fish_color_host_remote     83c092
set -U fish_color_status          e67e80
set -U fish_color_cancel          e67e80
set -U fish_color_search_match    --background=dbbc7f

# Pager colors
set -U fish_pager_color_progress             5c6a72
set -U fish_pager_color_prefix               7fbbb3
set -U fish_pager_color_completion           d3c6aa
set -U fish_pager_color_description          5c6a72
set -U fish_pager_color_selected_background  --background=475258
set -U fish_pager_color_selected_prefix      7fbbb3 --bold
set -U fish_pager_color_selected_completion  d3c6aa --bold
