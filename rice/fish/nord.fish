# Theme: Nord
# Source: https://www.nordtheme.com
# Usage: source this file or copy to ~/.config/fish/conf.d/nord.fish
#   source ~/.config/fish/themes/nord.fish

# Fish color variables (hex without #)
set -U fish_color_normal          D8DEE9
set -U fish_color_command         81A1C1
set -U fish_color_keyword         B48EAD
set -U fish_color_quote           A3BE8C
set -U fish_color_redirection     88C0D0
set -U fish_color_end             B48EAD
set -U fish_color_error           BF616A
set -U fish_color_param           D8DEE9
set -U fish_color_valid_path      88C0D0 --underline
set -U fish_color_comment         4C566A
set -U fish_color_selection       --background=4C566A
set -U fish_color_operator        B48EAD
set -U fish_color_escape          EBCB8B
set -U fish_color_autosuggestion  4C566A
set -U fish_color_user            A3BE8C
set -U fish_color_host            81A1C1
set -U fish_color_host_remote     88C0D0
set -U fish_color_status          BF616A
set -U fish_color_cancel          BF616A
set -U fish_color_search_match    --background=EBCB8B

# Pager colors
set -U fish_pager_color_progress             4C566A
set -U fish_pager_color_prefix               81A1C1
set -U fish_pager_color_completion           D8DEE9
set -U fish_pager_color_description          4C566A
set -U fish_pager_color_selected_background  --background=4C566A
set -U fish_pager_color_selected_prefix      81A1C1 --bold
set -U fish_pager_color_selected_completion  D8DEE9 --bold
