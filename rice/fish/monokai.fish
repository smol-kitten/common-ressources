# Theme: Monokai
# Source: https://monokai.pro
# Usage: source this file or copy to ~/.config/fish/conf.d/monokai.fish
#   source ~/.config/fish/themes/monokai.fish

# Fish color variables (hex without #)
set -U fish_color_normal          F8F8F2
set -U fish_color_command         66D9E8
set -U fish_color_keyword         AE81FF
set -U fish_color_quote           A6E22E
set -U fish_color_redirection     A1EFE4
set -U fish_color_end             AE81FF
set -U fish_color_error           F92672
set -U fish_color_param           F8F8F2
set -U fish_color_valid_path      A1EFE4 --underline
set -U fish_color_comment         75715E
set -U fish_color_selection       --background=75715E
set -U fish_color_operator        AE81FF
set -U fish_color_escape          F4BF75
set -U fish_color_autosuggestion  75715E
set -U fish_color_user            A6E22E
set -U fish_color_host            66D9E8
set -U fish_color_host_remote     A1EFE4
set -U fish_color_status          F92672
set -U fish_color_cancel          F92672
set -U fish_color_search_match    --background=F4BF75

# Pager colors
set -U fish_pager_color_progress             75715E
set -U fish_pager_color_prefix               66D9E8
set -U fish_pager_color_completion           F8F8F2
set -U fish_pager_color_description          75715E
set -U fish_pager_color_selected_background  --background=75715E
set -U fish_pager_color_selected_prefix      66D9E8 --bold
set -U fish_pager_color_selected_completion  F8F8F2 --bold
