# Theme: Tokyo Night
# Source: https://github.com/enkia/tokyo-night-vscode-theme
# Usage: source this file or copy to ~/.config/fish/conf.d/tokyo-night.fish
#   source ~/.config/fish/themes/tokyo-night.fish

# Fish color variables (hex without #)
set -U fish_color_normal          C0CAF5
set -U fish_color_command         7AA2F7
set -U fish_color_keyword         BB9AF7
set -U fish_color_quote           9ECE6A
set -U fish_color_redirection     7DCFFF
set -U fish_color_end             BB9AF7
set -U fish_color_error           F7768E
set -U fish_color_param           C0CAF5
set -U fish_color_valid_path      7DCFFF --underline
set -U fish_color_comment         414868
set -U fish_color_selection       --background=283457
set -U fish_color_operator        BB9AF7
set -U fish_color_escape          E0AF68
set -U fish_color_autosuggestion  414868
set -U fish_color_user            9ECE6A
set -U fish_color_host            7AA2F7
set -U fish_color_host_remote     7DCFFF
set -U fish_color_status          F7768E
set -U fish_color_cancel          F7768E
set -U fish_color_search_match    --background=E0AF68

# Pager colors
set -U fish_pager_color_progress             414868
set -U fish_pager_color_prefix               7AA2F7
set -U fish_pager_color_completion           C0CAF5
set -U fish_pager_color_description          414868
set -U fish_pager_color_selected_background  --background=283457
set -U fish_pager_color_selected_prefix      7AA2F7 --bold
set -U fish_pager_color_selected_completion  C0CAF5 --bold
