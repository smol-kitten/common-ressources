{
    "layer": "top",
    "position": "bottom",
    "height": 40,
    "spacing": 0,
    "exclusive": true,

    "modules-left": [
        "custom/start",
        "hyprland/workspaces",
        "hyprland/window"
    ],
    "modules-center": [],
    "modules-right": [
        "tray",
        "cpu",
        "memory",
        "pulseaudio",
        "network",
        "battery",
        "clock",
        "custom/power"
    ],

    "custom/start": {
        "format": "",
        "on-click": "rofi -show drun -show-icons",
        "tooltip": false
    },

    "hyprland/workspaces": {
        "format": "{id}",
        "on-click": "activate",
        "sort-by-number": true,
        "active-only": false
    },

    "hyprland/window": {
        "max-length": 50,
        "separate-outputs": true,
        "format": "{}"
    },

    "clock": {
        "format": " {:%H:%M   %a %d/%m/%Y}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "interval": 30
    },

    "cpu": {
        "format": " {usage}%",
        "tooltip": false,
        "interval": 5
    },

    "memory": {
        "format": " {used:.1f}G",
        "interval": 10
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "󰝟",
        "format-icons": {
            "headphone": "",
            "default": ["", "", ""]
        },
        "on-click": "pavucontrol",
        "scroll-step": 5
    },

    "network": {
        "format-wifi": " {essid}",
        "format-ethernet": "󰈀",
        "format-disconnected": "󰖪",
        "tooltip-format-wifi": "{essid} ({signalStrength}%)  {ipaddr}",
        "tooltip-format-ethernet": "{ifname}  {ipaddr}",
        "on-click": "nm-connection-editor"
    },

    "battery": {
        "format": "{icon} {capacity}%",
        "format-charging": "󰂄 {capacity}%",
        "format-plugged": "󰚥 {capacity}%",
        "format-icons": ["󰁺","󰁻","󰁼","󰁽","󰁾","󰁿","󰂀","󰂁","󰂂","󰁹"],
        "states": { "warning": 30, "critical": 15 },
        "interval": 60
    },

    "tray": {
        "spacing": 6,
        "icon-size": 16
    },

    "custom/power": {
        "format": "⏻",
        "on-click": "rofi -show power-menu -modi power-menu:rofi-power-menu",
        "tooltip": false
    }
}
