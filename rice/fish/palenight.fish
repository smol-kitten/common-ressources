# Theme: Palenight
# Source: https://github.com/whizkydee/vscode-palenight-theme
# Usage: source this file or copy to ~/.config/fish/conf.d/palenight.fish
#   source ~/.config/fish/themes/palenight.fish

# Fish color variables (hex without #)
set -U fish_color_normal          a6accd
set -U fish_color_command         82aaff
set -U fish_color_keyword         c792ea
set -U fish_color_quote           c3e88d
set -U fish_color_redirection     89ddff
set -U fish_color_end             c792ea
set -U fish_color_error           f07178
set -U fish_color_param           a6accd
set -U fish_color_valid_path      89ddff --underline
set -U fish_color_comment         434758
set -U fish_color_selection       --background=32374d
set -U fish_color_operator        c792ea
set -U fish_color_escape          ffcb6b
set -U fish_color_autosuggestion  434758
set -U fish_color_user            c3e88d
set -U fish_color_host            82aaff
set -U fish_color_host_remote     89ddff
set -U fish_color_status          f07178
set -U fish_color_cancel          f07178
set -U fish_color_search_match    --background=ffcb6b

# Pager colors
set -U fish_pager_color_progress             434758
set -U fish_pager_color_prefix               82aaff
set -U fish_pager_color_completion           a6accd
set -U fish_pager_color_description          434758
set -U fish_pager_color_selected_background  --background=32374d
set -U fish_pager_color_selected_prefix      82aaff --bold
set -U fish_pager_color_selected_completion  a6accd --bold
