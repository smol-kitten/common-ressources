# programming git config — Tokyo Night
# Usage: add to ~/.gitconfig:
#   [include]
#       path = ~/.config/git/rice.conf

[alias]
    l   = log --oneline --graph --decorate --all
    s   = status --short --branch
    co  = checkout
    sw  = switch
    br  = branch
    aa  = add -A
    cm  = commit -m
    ca  = commit --amend --no-edit
    pu  = push
    puf = push --force-with-lease
    pl  = pull --rebase
    d   = diff
    ds  = diff --staged
    rs  = restore --staged
    lg  = log --graph --pretty=format:'%C(auto)%h%d %s %C(dim)%an %ar'
    who = shortlog -sn --no-merges
    ref = reflog --pretty=format:'%C(auto)%h %gd %gs %C(dim)%ar'

[color "status"]
    added     = "#9ece6a" bold
    changed   = "#e0af68"
    untracked = "#f7768e"

[core]
    pager = delta

[delta]
    syntax-theme = tokyonight_night
    line-numbers = true
    side-by-side = true
    navigate     = true

[interactive]
    diffFilter = delta --color-only
