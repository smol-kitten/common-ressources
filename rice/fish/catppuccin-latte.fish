# Theme: Catppuccin Latte
# Source: https://catppuccin.com
# Usage: source this file or copy to ~/.config/fish/conf.d/catppuccin-latte.fish
#   source ~/.config/fish/themes/catppuccin-latte.fish

# Fish color variables (hex without #)
set -U fish_color_normal          4c4f69
set -U fish_color_command         1e66f5
set -U fish_color_keyword         ea76cb
set -U fish_color_quote           40a02b
set -U fish_color_redirection     179299
set -U fish_color_end             ea76cb
set -U fish_color_error           d20f39
set -U fish_color_param           4c4f69
set -U fish_color_valid_path      179299 --underline
set -U fish_color_comment         6c6f85
set -U fish_color_selection       --background=acb0be
set -U fish_color_operator        ea76cb
set -U fish_color_escape          df8e1d
set -U fish_color_autosuggestion  6c6f85
set -U fish_color_user            40a02b
set -U fish_color_host            1e66f5
set -U fish_color_host_remote     179299
set -U fish_color_status          d20f39
set -U fish_color_cancel          d20f39
set -U fish_color_search_match    --background=df8e1d

# Pager colors
set -U fish_pager_color_progress             6c6f85
set -U fish_pager_color_prefix               1e66f5
set -U fish_pager_color_completion           4c4f69
set -U fish_pager_color_description          6c6f85
set -U fish_pager_color_selected_background  --background=acb0be
set -U fish_pager_color_selected_prefix      1e66f5 --bold
set -U fish_pager_color_selected_completion  4c4f69 --bold
