# Theme: One Dark
# Source: https://github.com/atom/atom
# Usage: source this file or copy to ~/.config/fish/conf.d/one-dark.fish
#   source ~/.config/fish/themes/one-dark.fish

# Fish color variables (hex without #)
set -U fish_color_normal          ABB2BF
set -U fish_color_command         61AFEF
set -U fish_color_keyword         C678DD
set -U fish_color_quote           98C379
set -U fish_color_redirection     56B6C2
set -U fish_color_end             C678DD
set -U fish_color_error           E06C75
set -U fish_color_param           ABB2BF
set -U fish_color_valid_path      56B6C2 --underline
set -U fish_color_comment         5C6370
set -U fish_color_selection       --background=3E4451
set -U fish_color_operator        C678DD
set -U fish_color_escape          E5C07B
set -U fish_color_autosuggestion  5C6370
set -U fish_color_user            98C379
set -U fish_color_host            61AFEF
set -U fish_color_host_remote     56B6C2
set -U fish_color_status          E06C75
set -U fish_color_cancel          E06C75
set -U fish_color_search_match    --background=E5C07B

# Pager colors
set -U fish_pager_color_progress             5C6370
set -U fish_pager_color_prefix               61AFEF
set -U fish_pager_color_completion           ABB2BF
set -U fish_pager_color_description          5C6370
set -U fish_pager_color_selected_background  --background=3E4451
set -U fish_pager_color_selected_prefix      61AFEF --bold
set -U fish_pager_color_selected_completion  ABB2BF --bold
