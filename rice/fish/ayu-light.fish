# Theme: Ayu Light
# Source: https://github.com/dempfi/ayu
# Usage: source this file or copy to ~/.config/fish/conf.d/ayu-light.fish
#   source ~/.config/fish/themes/ayu-light.fish

# Fish color variables (hex without #)
set -U fish_color_normal          575F66
set -U fish_color_command         41A6D9
set -U fish_color_keyword         A37ACC
set -U fish_color_quote           86B300
set -U fish_color_redirection     4DBF99
set -U fish_color_end             A37ACC
set -U fish_color_error           FF3333
set -U fish_color_param           575F66
set -U fish_color_valid_path      4DBF99 --underline
set -U fish_color_comment         5C6773
set -U fish_color_selection       --background=D3D3D3
set -U fish_color_operator        A37ACC
set -U fish_color_escape          F29718
set -U fish_color_autosuggestion  5C6773
set -U fish_color_user            86B300
set -U fish_color_host            41A6D9
set -U fish_color_host_remote     4DBF99
set -U fish_color_status          FF3333
set -U fish_color_cancel          FF3333
set -U fish_color_search_match    --background=F29718

# Pager colors
set -U fish_pager_color_progress             5C6773
set -U fish_pager_color_prefix               41A6D9
set -U fish_pager_color_completion           575F66
set -U fish_pager_color_description          5C6773
set -U fish_pager_color_selected_background  --background=D3D3D3
set -U fish_pager_color_selected_prefix      41A6D9 --bold
set -U fish_pager_color_selected_completion  575F66 --bold
