{
  "schema_version": 1,
  "description": "Authoritative sources for each data domain. Useful for re-verification and update scheduling.",
  "last_updated": "2026-07-01",
  "domains": [
    {
      "domain": "science/elements",
      "files": ["science/elements/elements.json"],
      "source": "IUPAC Commission on Isotopic Abundances and Atomic Weights (CIAAW)",
      "source_url": "https://iupac.qmul.ac.uk/AtWt/",
      "license": "public domain",
      "update_frequency": "on IUPAC publication (every few years)",
      "last_verified": "2026-06-17",
      "notes": "Use IUPAC 2021 standard atomic weights. Abridged to 5 significant figures."
    },
    {
      "domain": "geo/countries",
      "files": ["geo/countries/countries.json"],
      "source": "ISO 3166 Maintenance Agency / UN Statistics Division",
      "source_url": "https://www.iso.org/iso-3166-country-codes.html",
      "license": "public domain",
      "update_frequency": "on ISO 3166 changes (rare)",
      "last_verified": "2026-06-17",
      "notes": "Currency codes should be checked against current adoption. Bulgaria adopted EUR 2026-01-01."
    },
    {
      "domain": "geo/currencies",
      "files": ["geo/currencies/currencies.json"],
      "source": "ISO 4217 / Wikipedia",
      "source_url": "https://www.iso.org/iso-4217-currency-codes.html",
      "license": "public domain",
      "update_frequency": "on currency adoption/withdrawal events",
      "last_verified": "2026-07-01",
      "notes": "Decimal places per ISO 4217. Multi-country currencies list primary country only."
    },
    {
      "domain": "geo/airports",
      "files": ["geo/airports/airports.json"],
      "source": "IATA / OurAirports",
      "source_url": "https://ourairports.com/data/",
      "license": "public domain (OurAirports CC0)",
      "update_frequency": "annually",
      "last_verified": "2026-06-17",
      "notes": "Major airports (scheduled commercial service) only. Coordinates ±0.01°."
    },
    {
      "domain": "geo/timezones",
      "files": ["geo/timezones/timezones.json"],
      "source": "IANA Time Zone Database (tzdata)",
      "source_url": "https://www.iana.org/time-zones",
      "license": "public domain",
      "update_frequency": "on tzdata releases (several per year for DST changes)",
      "last_verified": "2026-06-17",
      "notes": "UTC offsets are standard time offsets; some zones observe DST."
    },
    {
      "domain": "geo/mountains",
      "files": ["geo/mountains/peaks.json"],
      "source": "Wikipedia / National Geographic / SRTM",
      "source_url": "https://en.wikipedia.org/wiki/List_of_highest_mountains_on_Earth",
      "license": "public domain",
      "update_frequency": "rarely (survey updates)",
      "last_verified": "2026-07-01",
      "notes": "Elevations per latest geodetic surveys. Everest updated to 8849m in 2020."
    },
    {
      "domain": "geo/rivers",
      "files": ["geo/rivers/rivers.json"],
      "source": "Wikipedia / USGS",
      "source_url": "https://en.wikipedia.org/wiki/List_of_rivers_by_length",
      "license": "public domain",
      "update_frequency": "rarely",
      "last_verified": "2026-07-01",
      "notes": "River lengths are contested and may vary by measurement methodology."
    },
    {
      "domain": "i18n/languages",
      "files": ["i18n/languages/languages.json"],
      "source": "Ethnologue / ISO 639 / SIL International",
      "source_url": "https://www.ethnologue.com/",
      "license": "ISO 639 codes are public domain",
      "update_frequency": "on ISO 639 changes",
      "last_verified": "2026-06-17",
      "notes": "Speaker counts are approximate and change with demographic data."
    },
    {
      "domain": "science/constants",
