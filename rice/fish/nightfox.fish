# Theme: Nightfox
# Source: https://github.com/EdenEast/nightfox.nvim
# Usage: source this file or copy to ~/.config/fish/conf.d/nightfox.fish
#   source ~/.config/fish/themes/nightfox.fish

# Fish color variables (hex without #)
set -U fish_color_normal          CDCECF
set -U fish_color_command         719CD6
set -U fish_color_keyword         9D79D6
set -U fish_color_quote           81B29A
set -U fish_color_redirection     63CDCF
set -U fish_color_end             9D79D6
set -U fish_color_error           C94F6D
set -U fish_color_param           CDCECF
set -U fish_color_valid_path      63CDCF --underline
set -U fish_color_comment         575860
set -U fish_color_selection       --background=2B3B51
set -U fish_color_operator        9D79D6
set -U fish_color_escape          DBC074
set -U fish_color_autosuggestion  575860
set -U fish_color_user            81B29A
set -U fish_color_host            719CD6
set -U fish_color_host_remote     63CDCF
set -U fish_color_status          C94F6D
set -U fish_color_cancel          C94F6D
set -U fish_color_search_match    --background=DBC074

# Pager colors
set -U fish_pager_color_progress             575860
set -U fish_pager_color_prefix               719CD6
set -U fish_pager_color_completion           CDCECF
set -U fish_pager_color_description          575860
set -U fish_pager_color_selected_background  --background=2B3B51
set -U fish_pager_color_selected_prefix      719CD6 --bold
set -U fish_pager_color_selected_completion  CDCECF --bold
