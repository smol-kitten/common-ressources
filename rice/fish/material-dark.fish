# Theme: Material Dark
# Source: https://material-theme.com
# Usage: source this file or copy to ~/.config/fish/conf.d/material-dark.fish
#   source ~/.config/fish/themes/material-dark.fish

# Fish color variables (hex without #)
set -U fish_color_normal          EEFFFF
set -U fish_color_command         82AAFF
set -U fish_color_keyword         C792EA
set -U fish_color_quote           C3E88D
set -U fish_color_redirection     89DDFF
set -U fish_color_end             C792EA
set -U fish_color_error           FF5370
set -U fish_color_param           EEFFFF
set -U fish_color_valid_path      89DDFF --underline
set -U fish_color_comment         B0BEC5
set -U fish_color_selection       --background=546E7A
set -U fish_color_operator        C792EA
set -U fish_color_escape          FFCB6B
set -U fish_color_autosuggestion  B0BEC5
set -U fish_color_user            C3E88D
set -U fish_color_host            82AAFF
set -U fish_color_host_remote     89DDFF
set -U fish_color_status          FF5370
set -U fish_color_cancel          FF5370
set -U fish_color_search_match    --background=FFCB6B

# Pager colors
set -U fish_pager_color_progress             B0BEC5
set -U fish_pager_color_prefix               82AAFF
set -U fish_pager_color_completion           EEFFFF
set -U fish_pager_color_description          B0BEC5
set -U fish_pager_color_selected_background  --background=546E7A
set -U fish_pager_color_selected_prefix      82AAFF --bold
set -U fish_pager_color_selected_completion  EEFFFF --bold
