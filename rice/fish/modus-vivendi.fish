# Theme: Modus Vivendi
# Source: https://protesilaos.com/emacs/modus-themes
# Usage: source this file or copy to ~/.config/fish/conf.d/modus-vivendi.fish
#   source ~/.config/fish/themes/modus-vivendi.fish

# Fish color variables (hex without #)
set -U fish_color_normal          FFFFFF
set -U fish_color_command         2FAFFF
set -U fish_color_keyword         FEACD0
set -U fish_color_quote           44BC44
set -U fish_color_redirection     00D3D0
set -U fish_color_end             FEACD0
set -U fish_color_error           FF5F5F
set -U fish_color_param           FFFFFF
set -U fish_color_valid_path      00D3D0 --underline
set -U fish_color_comment         595959
set -U fish_color_selection       --background=2C2C2C
set -U fish_color_operator        FEACD0
set -U fish_color_escape          D0BC00
set -U fish_color_autosuggestion  595959
set -U fish_color_user            44BC44
set -U fish_color_host            2FAFFF
set -U fish_color_host_remote     00D3D0
set -U fish_color_status          FF5F5F
set -U fish_color_cancel          FF5F5F
set -U fish_color_search_match    --background=D0BC00

# Pager colors
set -U fish_pager_color_progress             595959
set -U fish_pager_color_prefix               2FAFFF
set -U fish_pager_color_completion           FFFFFF
set -U fish_pager_color_description          595959
set -U fish_pager_color_selected_background  --background=2C2C2C
set -U fish_pager_color_selected_prefix      2FAFFF --bold
set -U fish_pager_color_selected_completion  FFFFFF --bold
