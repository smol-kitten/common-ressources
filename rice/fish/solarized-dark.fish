# Theme: Solarized Dark
# Source: https://ethanschoonover.com/solarized/
# Usage: source this file or copy to ~/.config/fish/conf.d/solarized-dark.fish
#   source ~/.config/fish/themes/solarized-dark.fish

# Fish color variables (hex without #)
set -U fish_color_normal          839496
set -U fish_color_command         268BD2
set -U fish_color_keyword         D33682
set -U fish_color_quote           859900
set -U fish_color_redirection     2AA198
set -U fish_color_end             D33682
set -U fish_color_error           DC322F
set -U fish_color_param           839496
set -U fish_color_valid_path      2AA198 --underline
set -U fish_color_comment         002B36
set -U fish_color_selection       --background=073642
set -U fish_color_operator        D33682
set -U fish_color_escape          B58900
set -U fish_color_autosuggestion  002B36
set -U fish_color_user            859900
set -U fish_color_host            268BD2
set -U fish_color_host_remote     2AA198
set -U fish_color_status          DC322F
set -U fish_color_cancel          DC322F
set -U fish_color_search_match    --background=B58900

# Pager colors
set -U fish_pager_color_progress             002B36
set -U fish_pager_color_prefix               268BD2
set -U fish_pager_color_completion           839496
set -U fish_pager_color_description          002B36
set -U fish_pager_color_selected_background  --background=073642
set -U fish_pager_color_selected_prefix      268BD2 --bold
set -U fish_pager_color_selected_completion  839496 --bold
